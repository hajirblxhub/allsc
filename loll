local function GetMixTotemUUID(targetId)
    local uuid = nil
    pcall(function()
        local inv = PlayerData:GetExpect("Inventory")
        if inv and inv.Totems then
            for _, item in ipairs(inv.Totems) do
                if item.Id == targetId then
                    uuid = item.UUID
                    break
