local Workspace = game:GetService("Workspace")
local LocalPlayer = game.Players.LocalPlayer
local megCheckRadius = 150
local autoEventTPEnabled = false
local selectedEvents = {}
local createdEventPlatform = nil

local eventData = {
    ["Worm Hunt"] = {
        TargetName = "Model",
        Locations = {
